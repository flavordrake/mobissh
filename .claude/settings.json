{
  "hooks": {
    "SessionEnd": [
      {
        "matcher": "clear",
        "hooks": [
          {
            "type": "command",
            "command": "echo '\n--- Pre-clear checklist ---\n1. Commit uncommitted changes (git status)\n2. Push to origin if needed\n3. Review MEMORY.md for stale entries\n4. Check active bot delegations: gh issue list -l bot\n5. If next task is /integrate: bot branches ready?\n'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",

      "Bash(git *)",
      "Bash(gh *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(./scripts/*)",
      "Bash(scripts/*)",
      "Bash(nohup *)",
      "Bash(curl *)",
      "Bash(docker *)",
      "Bash(python3 *)",
      "Bash(semgrep *)",
      "Bash(adb *)",

      "Bash(lsof *)",
      "Bash(ss *)",
      "Bash(kill *)",
      "Bash(pkill *)",
      "Bash(jobs)",
      "Bash(ps *)",

      "Bash(ls *)",
      "Bash(tree *)",
      "Bash(sort *)",
      "Bash(sleep *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(diff *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(date *)",
      "Bash(test *)",

      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rm *)",
      "Bash(chmod *)",
      "Bash(echo *)",
      "Bash(env *)",
      "Bash(export *)",
      "Bash(BASE_PATH=*)",
      "Bash(PORT=*)"
    ]
  }
}
